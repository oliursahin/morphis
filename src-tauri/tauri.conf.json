{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "memphis",
  "version": "0.1.0",
  "identifier": "cat.march.memphis",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "memphis",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDlFOTQzRDI4RTdGRDMyNEQKUldSTk12M25LRDJVbnRRR041VGR3T0hzeTZNQzhoOVhMaWhpS1Q4b1BtRGFmS2hEY2hpYmNJazIK",
      "endpoints": [
        "https://github.com/oliursahin/memphis/releases/latest/download/latest.json"
      ]
    }
  }
}
